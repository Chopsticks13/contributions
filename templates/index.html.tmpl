<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Open Source Contributions — Zak Hassan</title>
    <style>
        :root {
            --bg: #ffffff;
            --fg: #1a1a1a;
            --muted: #6b7280;
            --border: #e5e7eb;
            --card-bg: #f9fafb;
            --merged: #16a34a;
            --open: #ca8a04;
            --closed: #dc2626;
            --link: #2563eb;
            --toggle-bg: #e5e7eb;
        }

        [data-theme="dark"] {
            --bg: #0d1117;
            --fg: #e6edf3;
            --muted: #8b949e;
            --border: #30363d;
            --card-bg: #161b22;
            --merged: #3fb950;
            --open: #d29922;
            --closed: #f85149;
            --link: #58a6ff;
            --toggle-bg: #30363d;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg);
            color: var(--fg);
            line-height: 1.6;
            padding: 2rem 1rem;
            max-width: 800px;
            margin: 0 auto;
            transition: background 0.2s, color 0.2s;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 2.5rem;
        }

        header div h1 {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        header div p {
            color: var(--muted);
            font-size: 0.9rem;
        }

        .theme-toggle {
            background: none;
            border: none;
            cursor: pointer;
            padding: 0.5rem;
            border-radius: 8px;
            color: var(--muted);
            transition: color 0.2s;
        }

        .theme-toggle:hover {
            color: var(--fg);
        }

        .theme-toggle svg {
            width: 24px;
            height: 24px;
            fill: currentColor;
        }

        .stats {
            display: flex;
            gap: 1.5rem;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }

        .stat {
            font-size: 0.85rem;
            color: var(--muted);
        }

        .stat strong {
            color: var(--fg);
            font-size: 1.25rem;
            display: block;
        }

        .repo-group {
            margin-bottom: 2rem;
        }

        .repo-group h2 {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 0.75rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid var(--border);
        }

        .repo-group h2 a {
            color: var(--fg);
            text-decoration: none;
        }

        .repo-group h2 a:hover {
            color: var(--link);
        }

        .section-divider {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-top: 2.5rem;
            margin-bottom: 1rem;
        }

        .pr {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            padding: 0.75rem;
            border-radius: 6px;
            margin-bottom: 0.25rem;
        }

        .pr:hover {
            background: var(--card-bg);
        }

        .badge {
            font-size: 0.7rem;
            font-weight: 600;
            padding: 0.15rem 0.5rem;
            border-radius: 12px;
            white-space: nowrap;
            margin-top: 0.15rem;
        }

        .badge.merged {
            background: var(--merged);
            color: #fff;
        }

        .badge.open {
            background: var(--open);
            color: #fff;
        }

        .badge.closed {
            background: var(--closed);
            color: #fff;
        }

        .pr-info {
            flex: 1;
            min-width: 0;
        }

        .pr-title {
            font-size: 0.9rem;
            font-weight: 500;
        }

        .pr-title a {
            color: var(--fg);
            text-decoration: none;
        }

        .pr-title a:hover {
            color: var(--link);
        }

        .pr-meta {
            font-size: 0.8rem;
            color: var(--muted);
            margin-top: 0.15rem;
        }

        footer {
            margin-top: 3rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .footer-left {
            font-size: 0.8rem;
            color: var(--muted);
        }

        .footer-left a {
            color: var(--muted);
            text-decoration: underline;
        }

        .social-links {
            display: flex;
            gap: 1rem;
            align-items: center;
        }

        .social-links a {
            color: var(--muted);
            transition: color 0.2s;
        }

        .social-links a:hover {
            color: var(--fg);
        }

        .social-links svg {
            width: 20px;
            height: 20px;
            fill: currentColor;
        }

        @media (max-width: 600px) {
            body {
                padding: 1.5rem 1rem;
            }

            .stats {
                gap: 1rem;
            }

            footer {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>
<body>
    <header>
        <div>
            <h1>Open Source Contributions</h1>
            <p>Tinkering with the tools I use daily</p>
        </div>
        <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
            <!-- GitHub Invertocat logo -->
            <svg viewBox="0 0 16 16">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
        </button>
    </header>

    <div class="stats">
        <div class="stat">
            <strong>{{total}}</strong>
            Total PRs
        </div>
        <div class="stat">
            <strong>{{merged}}</strong>
            Merged
        </div>
        <div class="stat">
            <strong>{{open}}</strong>
            Open
        </div>
        <div class="stat">
            <strong>{{repos}}</strong>
            Repos
        </div>
    </div>

    {{content}}

    <footer>
        <div class="footer-left">
            Auto-updated daily via <a href="https://github.com/Chopsticks13/oss-contributions">GitHub Actions</a>. Last updated: {{updated}}.
        </div>
        <div class="social-links">
            <!-- LinkedIn -->
            <a href="https://www.linkedin.com/in/zakaria-hassan/" target="_blank" rel="noopener" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <!-- Medium -->
            <a href="https://medium.com/@zakaria.hassan" target="_blank" rel="noopener" aria-label="Medium">
                <svg viewBox="0 0 24 24"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
            </a>
            <!-- GitHub -->
            <a href="https://github.com/Chopsticks13" target="_blank" rel="noopener" aria-label="GitHub">
                <svg viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            </a>
        </div>
    </footer>

    <script>
        function toggleTheme() {
            const current = document.documentElement.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
        }

        // Load saved preference or use system default
        const saved = localStorage.getItem('theme');
        if (saved) {
            document.documentElement.setAttribute('data-theme', saved);
        } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.setAttribute('data-theme', 'dark');
        }
    </script>
</body>
</html>
